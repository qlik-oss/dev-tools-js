{
  "name": "@qlik/prettier-config",
  "version": "0.4.36",
  "description": "Qlik's shared Prettier config",
  "license": "ISC",
  "repository": "git@github.com:qlik-oss/dev-tools-js.git",
  "main": "./prettier.config.js",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
