{
  "name": "@qlik/eslint-config",
  "version": "2.0.14",
  "description": "Qlik's ESLint configs",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qlik-oss/dev-tools-js.git"
  },
  "files": [
    "src",
    "!**/__tests__"
  ],
  "type": "module",
  "module": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": "./src/index.js"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "format:check": "oxfmt --check .",
    "format:write": "oxfmt .",
    "test": "vitest run && ./test/verify-configs.sh"
  },
  "dependencies": {
    "@eslint-react/eslint-plugin": "^5.9.5",
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/utils": "^8.62.0",
    "@vitest/eslint-plugin": "^1.6.20",
    "confusing-browser-globals": "^1.0.11",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-node": "^0.4.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.0",
    "eslint-plugin-testing-library": "^7.16.2",
    "globals": "^17.7.0",
    "typescript-eslint": "^8.62.0"
  },
  "devDependencies": {
    "@types/confusing-browser-globals": "^1.0.3",
    "@types/eslint-config-prettier": "^6.11.3"
  },
  "peerDependencies": {
    "eslint": "9.x || 10.x"
  },
  "engines": {
    "node": ">=20"
  }
}
