{
  "name": "@qlik/eslint-config",
  "version": "1.4.21",
  "description": "Qlik's ESLint configs",
  "repository": "git@github.com:qlik-oss/dev-tools-js.git",
  "license": "ISC",
  "type": "module",
  "exports": {
    ".": "./src/index.js"
  },
  "module": "./src/index.js",
  "types": "./src/index.d.ts",
  "files": [
    "src",
    "!**/__tests__"
  ],
  "scripts": {
    "check-types": "tsc --noEmit",
    "format:check": "cd ../.. && prettier --check 'packages/eslint-config' --ignore-unknown",
    "format:write": "cd ../.. && prettier --write 'packages/eslint-config' --ignore-unknown",
    "lint": "eslint .",
    "test": "vitest run && ./test/verify-configs.sh"
  },
  "dependencies": {
    "@eslint-react/eslint-plugin": "v3.0.0-beta.60",
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/utils": "^8.56.1",
    "@vitest/eslint-plugin": "^1.6.9",
    "confusing-browser-globals": "^1.0.11",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.7.1",
    "eslint-plugin-testing-library": "^7.16.0",
    "globals": "^17.3.0",
    "typescript-eslint": "^8.56.1"
  },
  "devDependencies": {
    "@qlik/tsconfig": "workspace:^",
    "@types/confusing-browser-globals": "^1.0.3",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/node": "^25.3.0",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "eslint": "10.x"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
