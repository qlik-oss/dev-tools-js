{
  "name": "@qlik/oxlint-config",
  "version": "0.6.3",
  "description": "Qlik's oxlint configs",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qlik-oss/dev-tools-js.git"
  },
  "files": [
    "src"
  ],
  "type": "module",
  "module": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "format:check": "oxfmt --check .",
    "format:write": "oxfmt .",
    "test": "vitest run && ./test/verify-configs.sh",
    "test:update": "./test/update-configs.sh"
  },
  "devDependencies": {
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.23.0"
  },
  "peerDependencies": {
    "oxlint": ">=1.61.0",
    "oxlint-tsgolint": ">=0.18.0"
  }
}
