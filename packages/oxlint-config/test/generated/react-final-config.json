{
  "categories": {
    "correctness": "deny",
    "suspicious": "deny"
  },
  "env": {
    "browser": true,
    "builtin": true
  },
  "globals": {},
  "ignorePatterns": [],
  "options": {
    "typeAware": true,
    "typeCheck": true
  },
  "overrides": [
    {
      "env": {
        "builtin": true,
        "commonjs": true,
        "node": true
      },
      "files": [
        "**/*.{cjs,cts}"
      ],
      "globals": null,
      "plugins": null,
      "rules": {
        "no-console": "allow"
      }
    }
  ],
  "plugins": [
    "react",
    "unicorn",
    "typescript",
    "oxc",
    "import"
  ],
  "rules": {
    "array-callback-return": [
      "deny",
      [
        {
          "allowImplicit": true
        }
      ]
    ],
    "block-scoped-var": "deny",
    "constructor-super": "deny",
    "default-case": [
      "deny",
      [
        {
          "commentPattern": "^no default$"
        }
      ]
    ],
    "default-case-last": "deny",
    "default-param-last": "deny",
    "eqeqeq": [
      "deny",
      [
        "always",
        {
          "null": "ignore"
        }
      ]
    ],
    "for-direction": "deny",
    "func-names": "warn",
    "import/default": "deny",
    "import/extensions": [
      "deny",
      [
        "ignorePackages",
        {
          "cjs": "never",
          "cts": "never",
          "js": "never",
          "jsx": "never",
          "mjs": "never",
          "mts": "never",
          "ts": "never",
          "tsx": "never"
        }
      ]
    ],
    "import/namespace": "deny",
    "import/no-absolute-path": "deny",
    "import/no-amd": "deny",
    "import/no-cycle": [
      "deny",
      [
        {
          "ignoreExternal": true
        }
      ]
    ],
    "import/no-duplicates": "deny",
    "import/no-dynamic-require": "warn",
    "import/no-empty-named-blocks": "allow",
    "import/no-mutable-exports": "deny",
    "import/no-named-as-default": "deny",
    "import/no-named-as-default-member": "deny",
    "import/no-named-default": "deny",
    "import/no-self-import": "deny",
    "import/no-unassigned-import": "deny",
    "import/no-webpack-loader-syntax": "deny",
    "new-cap": [
      "deny",
      [
        {
          "capIsNew": false,
          "capIsNewExceptions": [
            "Immutable.Map",
            "Immutable.Set",
            "Immutable.List"
          ],
          "newIsCap": true,
          "newIsCapExceptions": []
        }
      ]
    ],
    "no-alert": "deny",
    "no-array-constructor": "deny",
    "no-async-promise-executor": "deny",
    "no-await-in-loop": "deny",
    "no-caller": "deny",
    "no-class-assign": "deny",
    "no-compare-neg-zero": "deny",
    "no-cond-assign": "deny",
    "no-console": "warn",
    "no-const-assign": "deny",
    "no-constant-binary-expression": "deny",
    "no-constant-condition": "deny",
    "no-constructor-return": "deny",
    "no-control-regex": "deny",
    "no-debugger": "deny",
    "no-delete-var": "deny",
    "no-dupe-class-members": "deny",
    "no-dupe-else-if": "deny",
    "no-dupe-keys": "deny",
    "no-duplicate-case": "deny",
    "no-empty-character-class": "deny",
    "no-empty-pattern": "deny",
    "no-empty-static-block": "deny",
    "no-eval": "deny",
    "no-ex-assign": "deny",
    "no-extend-native": "deny",
    "no-extra-bind": "deny",
    "no-extra-boolean-cast": "deny",
    "no-func-assign": "deny",
    "no-global-assign": "deny",
    "no-import-assign": "deny",
    "no-inner-declarations": "deny",
    "no-invalid-regexp": "deny",
    "no-irregular-whitespace": "deny",
    "no-iterator": "deny",
    "no-labels": "deny",
    "no-lone-blocks": "deny",
    "no-lonely-if": "deny",
    "no-loop-func": "deny",
    "no-loss-of-precision": "deny",
    "no-misleading-character-class": "deny",
    "no-multi-assign": "deny",
    "no-nested-ternary": "deny",
    "no-new": "deny",
    "no-new-func": "deny",
    "no-new-native-nonconstructor": "deny",
    "no-nonoctal-decimal-escape": "deny",
    "no-obj-calls": "deny",
    "no-object-constructor": "deny",
    "no-param-reassign": [
      "deny",
      [
        {
          "ignorePropertyModificationsFor": [
            "prev",
            "acc",
            "accumulator",
            "e",
            "ctx",
            "context",
            "req",
            "request",
            "res",
            "response",
            "$scope",
            "staticContext",
            "sharedState",
            "state"
          ],
          "props": true
        }
      ]
    ],
    "no-promise-executor-return": "deny",
    "no-proto": "deny",
    "no-redeclare": "deny",
    "no-restricted-exports": [
      "deny",
      [
        {
          "restrictedNamedExports": [
            "default",
            "then"
          ]
        }
      ]
    ],
    "no-restricted-globals": [
      "deny",
