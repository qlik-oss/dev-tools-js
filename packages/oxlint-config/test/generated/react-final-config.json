    "no-return-assign": [
      "deny",
      [
        "always"
      ]
    ],
    "no-script-url": "deny",
    "no-self-assign": "deny",
    "no-self-compare": "deny",
    "no-sequences": "deny",
    "no-setter-return": "deny",
