      [
        "always",
        {
          "avoidQuotes": true,
          "ignoreConstructors": false
        }
      ]
    ],
    "operator-assignment": [
      "deny",
      [
        "always"
      ]
    ],
    "oxc/approx-constant": "deny",
    "oxc/bad-array-method-on-arguments": "deny",
    "oxc/bad-char-at-comparison": "deny",
    "oxc/bad-comparison-sequence": "deny",
    "oxc/bad-min-max-func": "deny",
