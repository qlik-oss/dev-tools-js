{
  "name": "dev-tools-js",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "empty-changeset": "changeset add --empty",
    "format:check": "oxfmt --check",
    "format:write": "oxfmt",
    "lint": "turbo run lint",
    "prepare-release": "changeset",
    "publish-packages": "changeset publish",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@qlik/oxfmt-config": "workspace:^",
    "oxfmt": "^0.40.0",
    "turbo": "^2.8.17"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.30.1",
  "pnpm": {
    "updateConfig": {
      "ignoreDependencies": [
        "eslint",
        "@eslint/js"
      ]
    }
  }
}
